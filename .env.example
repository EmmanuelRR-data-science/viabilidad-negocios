# =====================================================================
# GeoViabilidad Hook - Configuración de Variables de Entorno
# =====================================================================

# --- BASE DE DATOS (PostgreSQL + PostGIS) ---
DB_USER=admin
DB_PASSWORD=admin_password_safe
DB_HOST=127.0.0.1
DB_PORT=5435
DB_NAME=geoanalisis

# --- ENTORNO Y CONTROL DE DESARROLLO ---
# DEV_MODE=True activa simulaciones locales para Cognito y Mercado Pago.
# En producción, establecer a False.
DEV_MODE=True

# --- AWS INTEGRACIONES (S3, Bedrock & SES) ---
AWS_REGION=us-east-1
S3_REPORTS_BUCKET=viabilidad-hook-informes

# ID del Modelo de AWS Bedrock a invocar (Llama 3 70B Instruct en us-east-1)
# En Bedrock, el ID del Llama 3 70B suele ser: meta.llama3-70b-instruct-v1:0
# O para Llama 3.1 70B: meta.llama3-1-70b-instruct-v1:0
BEDROCK_MODEL_ID=meta.llama3-70b-instruct-v1:0

# --- MERCADO PAGO (Checkout Pro) ---
# Token de acceso (Sandbox para desarrollo, Producción en vivo)
MERCADOPAGO_ACCESS_TOKEN=tu_token_de_mercado_pago_aqui
